// =============================================================================
// IdeaForge — Database Schema
// =============================================================================
//
// Mirrors the teammate's Drizzle/Postgres backend (users, roadmaps, assumptions,
// milestones) so the frontend talks to a faithful, working API.
//
// SQLite is used here (sandbox constraint); the contract is identical.
// A `FirstStep` table is added to persist recommendations so the dashboard
// can render them without re-running the agent.
//
// Models:
//   User       — Session-based user identity (no real auth in sandbox)
//   Roadmap    — Central entity linking all 4 pipeline stages
//   Assumption — Risk-tagged beliefs extracted by the Stage 2 AI agent
//   Milestone  — 30/60/90-day plan items with HITL acceptance flag
//   FirstStep  — Smallest testable action recommended by Stage 4 agent
//
// Relations use cascading deletes: removing a User removes all their data.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Session-based user identity. In the sandbox environment, a single default
/// user is auto-provisioned on first request. A production system would use
/// real authentication (OAuth, magic links, etc.).
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  roadmaps  Roadmap[]
}

/// Central entity that ties together all 4 stages of the IdeaForge pipeline.
/// Status tracks which stage the user has reached:
///   draft       → intake completed, ready for assumption extraction
///   assumptions → assumptions generated, ready for milestone planning
///   milestones  → milestones generated, ready for first-step recommendation
///   complete    → all 4 stages completed
model Roadmap {
  id            String       @id @default(uuid())
  userId        String
  title         String       /// First 80 chars of rawIdea, used as display title
  rawIdea       String       /// The user's original idea text (unmodified)
  sixW3hSummary String?      /// JSON-encoded 6W3H fields (AI-inferred + user-provided)
  status        String       @default("draft") // draft | assumptions | milestones | complete
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assumptions   Assumption[]
  milestones    Milestone[]
  firstSteps    FirstStep[]

  @@index([userId])
}

/// Risk-tagged assumption extracted by the Stage 2 AI agent.
/// Each assumption represents an unvalidated belief the founder is making
/// about their idea (e.g., "users will pay $10/month for this").
model Assumption {
  id          String   @id @default(uuid())
  roadmapId   String
  statement   String   /// The assumption text
  riskLevel   String   @default("medium") // low | medium | high
  isValidated String   @default("pending") // pending | validated | invalidated
  focusHint   String?  /// Optional user-specified focus area for extraction
  createdAt   DateTime @default(now())
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
}

/// 30/60/90-day milestone generated by the Stage 3 AI agent.
/// The HITL (Human-in-the-Loop) pattern: isAccepted starts false,
/// and only becomes true when the user explicitly accepts via PATCH.
model Milestone {
  id          String    @id @default(uuid())
  roadmapId   String
  title       String
  description String?
  dayBucket   Int       /// 30, 60, or 90 — which phase of the roadmap
  orderIndex  Int       @default(0) /// Chronological order within the bucket
  isAccepted  Boolean   @default(false) /// HITL approval flag
  acceptedAt  DateTime? /// Timestamp of user acceptance (audit trail)
  createdAt   DateTime  @default(now())
  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
}

/// First-step recommendation from the Stage 4 AI agent.
/// Represents the single smallest testable action: 24h, no budget, no team.
model FirstStep {
  id                 String   @id @default(uuid())
  roadmapId          String
  action             String   /// The recommended action to take
  rationale          String   /// Why this action was chosen
  estimatedTimeHours Float    /// Expected time to complete (typically 1-4 hours)
  focusMilestoneId   String?  /// Optional: which milestone this action targets
  createdAt          DateTime @default(now())
  roadmap            Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
}
